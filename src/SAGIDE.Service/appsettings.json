{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5100"
      }
    }
  },
  "SAGIDE": {
    "PromptsPath": "../../prompts",
    "SkillsPath": "../../skills",
    "Scheduler": {
      "Enabled": true
    },
    "Database": {
      "Path": "",
      "DlqRetentionDays": 7
    },
    "Communication": {
      "MaxMessageSizeBytes": 10485760,
      "MaxBroadcastQueueSize": 10000,
      "BroadcastAllTasks": false
    },
    "Orchestration": {
      "MaxTaskHistoryInMemory": 1000,
      "BroadcastThrottleMs": 200,
      "MaxFileSizeChars": 32000,
      "WebApiBatchMaxItems": 50,
      "WebSearchBatchMaxItems": 20
    },
    "Caching": {
      "OutputCacheEnabled": false,
      "SearchCacheTtlMinutes": 0,
      "HealthPollIntervalSeconds": 30,
      "RoutingHintsTtlSeconds": 60,
      "PersistentSearchCacheTtlHours": 0,
      "SearchCacheRetentionDays": 30,
      "SearchCacheTtlByDomain": {
        "finance": 24,
        "research": 168,
        "robotics": 168,
        "notes": 720
      }
    },
    "RunTracing": {
      "Enabled": true,
      "Path": "~/reports/traces"
    },
    "Providers": {
      "Claude": { "MaxTokens": 4096 },
      "Gemini": { "MaxTokens": 4096 },
      "Codex": { "MaxTokens": 4096 },
      "Ollama": { "MaxTokens": 4096 }
    },
    "Notes": {
      "Enabled": true,
      "GraphPath": "<logseq path>",
      "Schedule": "0 0 * * *",
      "FilePatterns": ["*.md"],
      "ExcludeFolders": ["logseq", ".git", "assets", "node_modules"],
      "SourceTag": "logseq_notes",
      "TaskMarkers": ["TODO", "DOING", "LATER", "NOW", "NEXT", "IN-PROGRESS"],
      "SummaryModel": "ollama/qwen2.5:14b-instruct-q5_K_M@workstation",
      "SummaryModelFallback": "ollama/qwen2.5:7b-instruct-q4_K_M@mini"
    },
    "Rag": {
      "SearchEngines": "",
      "EmbeddingBatchSize": 32,
      "ChunkSize": 1500,
      "ChunkOverlap": 200,
      "CacheTtlHours": 4,
      "RateLimitDelayMs": 1000
    },
    "NamedPipeName": "SAGIDEPipe",
    "BuiltInTemplatesPath": "Orchestrator/Templates",
    "MaxConcurrentAgents": 5,
    "ApiKeys": {
      "Anthropic": "sk-",
      "OpenAI": "sk-",
      "Google": "AI"
    },
    "Ollama": {
      "Servers": [
        {
          "Name": "workstation",
          "BaseUrl": "http://server1:11434",
          "RagOrder": 0,
          "SearchUrl": "http://server1:8888",
          "Models": [
            "deepseek-coder-v2:16b",
            "deepseek-coder-v2:16b-lite-instruct-q6_K",
            "gemma3:27b",
            "nomic-embed-text:latest",
            "qwen2.5:14b-instruct-q5_K_M",
            "qwen2.5-coder:14b-instruct-q4_K_M",
            "qwen2.5-coder:32b-instruct-q4_K_M",
            "qwq:32b-preview-q4_K_M"
          ]
        },
        {
          "Name": "localhost",
          "BaseUrl": "http://localhost:11434",
          "RagOrder": 2,
          "SearchUrl": "http://localhost:8888",
          "Models": [
            "gemma2:2b",
            "gemma2:2b-instruct-q4_K_M",
            "gemma2:2b-instruct-q8_0",
            "gemma3:4b",
            "llama3.1:8b-instruct-q6_K",
            "nomic-embed-text:latest",
            "phi3:latest",
            "phi3.5:3.8b-mini-instruct-q8_0",
            "qwen2.5-coder:1.5b-instruct-q4_K_M",
            "qwen2.5-coder:3b-instruct",
            "qwen2.5-coder:3b-instruct-q4_K_M",
            "qwen2.5:3b"
          ]
        },
        {
          "Name": "mini",
          "BaseUrl": "http://server2:11434",
          "RagOrder" : 1,
          "SearchUrl" : "http://server2:8888",
          "Models": [
            "codeqwen:7b-chat-v1.5-q4_0",
            "gemma3:4b",
            "gemma3:4b-it-q4_K_M",
            "llama3.1:8b-instruct-q4_K_M",
            "llama3.1:8b-instruct-q6_K",
            "nomic-embed-text:latest",
            "phi3:latest",
            "qwen2.5-coder:7b-instruct-q4_K_M",
            "qwen2.5-coder:7b-instruct-q6_K",
            "qwen2.5:7b-instruct-q4_K_M"
          ]
        },
        {
          "Name": "edge",
          "BaseUrl": "http://server3:11434",
          "Models": [
            "gemma3:4b",
            "phi3.5:3.8b-mini-instruct-q4_K_M",
            "phi3.5:3.8b-mini-instruct-q8_0",
            "phi3:latest",
            "qwen2.5:3b",
            "qwen2.5-coder:3b-instruct-q4_K_M",
            "qwen2.5-coder:3b-instruct-q8_0",
            "stable-code:3b-code-q4_K_M"
          ]
        }
      ]
    },
    "OpenAICompatible": {
      "Servers": [
        {
          "Name": "orin",
          "BaseUrl": "http://server3:8000"
        }
      ]
    },
    "Timeouts": {
      "NamedPipeRequestMs": 7200000,
      "HealthCheckMs": 7200000,
      "PipeReconnectMs": 3000,
      "PipeReconnectMaxMs": 7200000,
      "TaskExecutionMs": 7200000,
      "Providers": {
        "Claude": 7200000,
        "Codex": 7200000,
        "Gemini": 7200000,
        "Ollama": 7200000
      }
    },
    "Git": {
      "AutoCommitResults": false,
      "Branch": "sag-agent-log"
    },
    "AgentLimits": {
      "Agents": {
        "CodeReview": {
          "MaxIterations": 5
        },
        "TestGeneration": {
          "MaxIterations": 5
        },
        "Refactoring": {
          "MaxIterations": 5
        },
        "Debug": {
          "MaxIterations": 5
        },
        "Documentation": {
          "MaxIterations": 5
        },
        "SecurityReview": {
          "MaxIterations": 3
        }
      }
    },
    "Routing": {
      "QualitySamplingEnabled": true,
      "SamplingRate": 0.25,
      "QualityProbeAllowlist": ["ollama/qwen2.5:14b-instruct-q5_K_M"],
      "Capabilities": {
        "fast_general":  "ollama/qwen2.5:14b-instruct-q5_K_M@workstation",
        "deep_analyst":  "ollama/qwen2.5:14b-instruct-q5_K_M@workstation",
        "coder":         "ollama/qwen2.5:14b-instruct-q5_K_M@workstation",
        "extractor":     "ollama/qwen2.5:14b-instruct-q5_K_M@workstation",
        "critic":        "ollama/gemma3:4b@edge"
      }
    },
    "WorkflowPolicy": {
      "Enabled": true,
      "ProtectedPathPatterns": [
        "**/.env",
        "**/.env.*",
        "**/appsettings*.json",
        "**/secrets/**",
        "**/*.pfx",
        "**/*.pem",
        "**/*.key",
        "**/*.p12"
      ],
      "BlockedAgentTypes": [],
      "MaxStepsPerWorkflow": 50
    }
  }
}
